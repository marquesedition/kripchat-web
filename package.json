{
  "name": "kripchat",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:export": "expo export --platform web",
    "deploy:web": "npx eas-cli deploy --prod",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:all": "npm run test:unit && npm run test:qa",
    "test:unit": "jest --runInBand",
    "test:unit:coverage": "jest --runInBand --coverage",
    "test:unit:report": "jest --runInBand --reporters=default --reporters=jest-html-reporters",
    "test:unit:report:open": "npm run test:unit:report && open jest_html_reporters.html",
    "qa:serve": "http-server dist -p 4193 -c-1 -e html",
    "test:qa": "npm run web:export && start-server-and-test 'npm run qa:serve' http://127.0.0.1:4193 'playwright test'",
    "test:qa:headed": "npm run web:export && start-server-and-test 'npm run qa:serve' http://127.0.0.1:4193 'playwright test --headed'",
    "qa:report:open": "playwright show-report",
    "test:qa:report": "npm run test:qa && npm run qa:report:open"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.10",
    "@expo/vector-icons": "^15.0.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.21",
    "@supabase/supabase-js": "^2.89.0",
    "@types/crypto-js": "^4.2.2",
    "crypto-js": "^4.2.0",
    "expo": "~55.0.0",
    "expo-blur": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-glass-effect": "~55.0.10",
    "expo-image-picker": "~55.0.19",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-location": "~55.1.8",
    "expo-modules-core": "~55.0.23",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.0",
    "babel-preset-expo": "^55.0.18",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "jest-html-reporters": "^3.1.7",
    "react-test-renderer": "^19.2.0",
    "start-server-and-test": "^3.0.2",
    "typescript": "~5.9.2"
  }
}
